# ===== Supabase =====
# Your Supabase project URL (find in Dashboard > Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Your Supabase anon/public key (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ===== Town Integration (optional) =====
# Town API base URL (defaults to https://townapi.aetherwit.com)
TOWN_API_URL=https://townapi.aetherwit.com

# Shared auth secret for Town backend SSO (keep this secret!)
TOWN_AUTH_SECRET=your-secret-here
